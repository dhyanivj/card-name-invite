# The URL of your Supabase project (provided by Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# The ANON public key for your Supabase project (provided by Supabase dashboard)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# The SUPABASE_SERVICE_KEY, safely kept on server side exclusively (NEVER EXPOSE TO FRONTEND code)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# The URL where the API server is hosted (if you're using Next.js routes, you can leave it empty or map to /api for local testing)
NEXT_PUBLIC_API_URL=/api
